postPrec = Lamy + prPrec
postmean = solve(postPrec) %*% (Lamy %*% yfull)
nreal = 50
postCov = solve(postPrec)
postReal = rmvnorm(nreal, postmean, postCov, checkSymmetry = FALSE)
# plot posterior realizations
par(mfrow = c(1, 1), oma = c(0, 0, 0, 0), mar = c(4, 4, 1, 1), pty = 'm')
