# load the multivariate normal library
library(mvtnorm)
# now some multivariate normal computations
# an 8-vector to start
nz = 8
s = seq(0,7,length=nz)
# define the mean
mean0 = rep(0,nz)
# get distances from each pair of the n points
distmat = as.matrix(dist(s))
cov0 = exp(-distmat^2)
# for numerical stability, we might add a little additional iid variance
cov0 = cov0 + diag(rep(1e-8,nz))
# make some realizations
nreal = 15
zrealizations = rmvnorm(nreal,mean0,cov0)
# plot the realizations over the spatial support
par(mfrow=c(1,1),oma=c(0,0,0,0),mar=c(4,4,1,1),pty='m')
matplot(s,t(zrealizations),type='l')
# now, redo this with a much denser set of points
# make sure you get values of s that exactly hit the integers 0..7.
nz=71
######## homework problem ####
# observe all elements of z with noise
yobs = c(1,.75,1.2,1.05,-.1,0,-1.2,-1.14)
varobs = rep(.01^2,length(yobs))
########
# now observe two elements of z with noise
# y1 = z(s=3) + e1
# y2 = z(s=4) + e2  with e1,e2 iid N(0,.02^2)
# y1 = .8; y2=-.9
yobs = c(.8,-.9)
sobs = c(2,4)
varobs = rep(.01^2,length(yobs))
# When n=8, this is elements 3 and 5 that we condition on, the line below
# does this more generally, but sobs better correspond to some s.
# make the likelihood precision Lamy
iobs = match(sobs,s)
Lamy = matrix(0,nrow=nz,ncol=nz); Lamy[iobs,iobs]=diag(1/varobs)
# check it
image(s,s,Lamy)
# now some multivariate normal computations
# an 8-vector to start
nz = 8
s = seq(0,7,length=nz)
# define the mean
mean0 = rep(0,nz)
# get distances from each pair of the n points
distmat = as.matrix(dist(s))
cov0 = exp(-distmat^2)
# for numerical stability, we might add a little additional iid variance
cov0 = cov0 + diag(rep(1e-8,nz))
# make some realizations
nreal = 15
zrealizations = rmvnorm(nreal,mean0,cov0)
# plot the realizations over the spatial support
par(mfrow=c(1,1),oma=c(0,0,0,0),mar=c(4,4,1,1),pty='m')
matplot(s,t(zrealizations),type='l')
# now, redo this with a much denser set of points
# make sure you get values of s that exactly hit the integers 0..7.
nz=71
######## homework problem ####
# observe all elements of z with noise
yobs = c(1,.75,1.2,1.05,-.1,0,-1.2,-1.14)
varobs = rep(.01^2,length(yobs))
########
# now observe two elements of z with noise
# y1 = z(s=3) + e1
# y2 = z(s=4) + e2  with e1,e2 iid N(0,.02^2)
# y1 = .8; y2=-.9
yobs = c(.8,-.9)
sobs = c(2,4)
varobs = rep(.01^2,length(yobs))
# make the likelihood precision Lamy
iobs = match(sobs,s)
Lamy = matrix(0,nrow=nz,ncol=nz); Lamy[iobs,iobs]=diag(1/varobs)
# check it
image(s,s,Lamy)
# make a full data vector
yfull = rep(0,nz); yfull[iobs] = yobs # why 0's for missing y's?
# make the prior mean and precion
prmean = rep(0,nz)
prPrec = solve(cov0)  # we numerical people hate computing this
# get the posterior precision
postPrec = Lamy + prPrec
postmean = solve(postPrec)%*%(Lamy%*%yfull)
# plot the posterior mean for z
matplot(s,t(zrealizations),type='l',col='grey70')
points(sobs,yobs,pch=16)
points(s,postmean,col='blue')  # interpolate?
# plot posterior realizations
postCov = solve(postPrec)   # yuck, again
postReal = rmvnorm(nreal,postmean,postCov)
# numerical roundoff makes postCov very slightly non-symmetric
postReal = rmvnorm(nreal,postmean,postCov,checkSymmetry=FALSE)
matlines(s,t(postReal),col='blue')
# add in 90% posterior prediction intervals
pi05 = qnorm(.05,mean=postmean,sd=sqrt(diag(postCov)))
pi95 = qnorm(.95,mean=postmean,sd=sqrt(diag(postCov)))
polygon(c(s,s[nz:1]),c(pi05,pi95[nz:1]))
## make conditional realizations using the conditional normal approach
## (I didn't cover this in class)
## This is a computationally more stable approach
iobs = match(sobs,s)
mean1 = mean0[iobs]
mean2 = mean0[-iobs]
Sig11 = cov0[iobs,iobs] + diag(varobs)
Sig22 = cov0[-iobs,-iobs]
Sig12 = cov0[iobs,-iobs]
Sig21 = t(Sig12)
# now compute the conditional mean and variance for z2|z1
condMean = Sig21%*%solve(Sig11,yobs)
condVar = Sig22 - Sig21%*%solve(Sig11,Sig12)
# plot the conditional mean E(z2|z1)
lines(s[-iobs],condMean,lty=2,lwd=2,col='grey30')
points(s[iobs],zobs,pch=16,col='grey30')
# make some realizations
nreal = 5
condReal = rmvnorm(nreal,condMean,condVar)
matlines(s[-iobs],t(condReal),col='grey30',lty=1,lwd=2)
# load the multivariate normal library
library(mvtnorm)
# Define the space
s = seq(0, 7, by = 0.1)
nz = length(s)
# Define the prior mean
mean0 = rep(0, nz)
# Compute the prior covariance matrix
distmat = as.matrix(dist(s))
cov0 = exp(-distmat^2) + diag(rep(1e-8, nz))
# Observations and their variance
yobs = c(1, .75, 1.2, 1.05, -0.1, 0, -1.2, -1.14)
sobs = 0:7
varobs = rep(0.1^2, length(yobs))
# Indices of observed locations
iobs = match(sobs, s)
# Likelihood precision matrix
Lamy = matrix(0, nrow = nz, ncol = nz)
Lamy[iobs, iobs] = diag(1 / varobs)
# Full data vector
yfull = rep(0, nz)
yfull[iobs] = yobs
# Prior mean and precision
prmean = rep(0, nz)
prPrec = solve(cov0)
# Posterior precision and mean
postPrec = Lamy + prPrec
postmean = solve(postPrec) %*% (Lamy %*% yfull)
# Number of posterior realizations
nreal = 50
# Posterior covariance matrix
postCov = solve(postPrec)
# Generate posterior realizations
postReal = rmvnorm(nreal, postmean, postCov)
